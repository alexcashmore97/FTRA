rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Divisions: public read, admin write
    match /divisions/{divisionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fighters: public read approved only, admin full write,
    // fighter can edit own profile fields, self-registration allowed
    match /fighters/{fighterId} {
      // Anyone can read (JS filters pending on the client; public pages only query status==approved)
      allow read: if true;

      // Admin can do anything
      allow create, delete: if isAdmin();
      allow update: if isAdmin();

      // Fighter can create their own doc (registration) with pending status
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.status == 'pending';

      // Fighter can update their own profile (limited fields)
      allow update: if isOwner(resource.data.uid)
        && request.resource.data.status == resource.data.status
        && request.resource.data.rankings == resource.data.rankings
        && request.resource.data.p4pRank == resource.data.p4pRank
        && request.resource.data.divisions == resource.data.divisions
        && request.resource.data.gender == resource.data.gender;

      // Claim: authenticated user can link themselves to an unclaimed profile
      allow update: if request.auth != null
        && resource.data.uid == null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == resource.data.status
        && request.resource.data.rankings == resource.data.rankings
        && request.resource.data.p4pRank == resource.data.p4pRank
        && request.resource.data.divisions == resource.data.divisions
        && request.resource.data.gender == resource.data.gender;
    }

    // Admins: own doc readable for role check, full access for admins
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow read, write: if isAdmin();
    }

    // Admin log: admin read/write only
    match /admin_log/{logId} {
      allow read, write: if isAdmin();
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
  }
}
