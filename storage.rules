rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fighter photos: public read, admin or owning fighter can upload
    match /fighters/{fighterId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        (isAdmin() || request.auth.uid == fighterId);
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
  }
}
