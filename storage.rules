rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fighter photos: public read, admin or owning user can upload
    match /fighters/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
    }

    // Show posters: public read, admin write
    match /shows/{showId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Post cover images: public read, admin write
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
  }
}
